# Airflow 구동에 필요한 로컬 환경 변수 설정 템플릿
# 이 파일을 복사하여 '.env' 파일로 이름을 변경한 뒤 사용하십시오.
# (실제 값은 절대 깃허브에 커밋되지 않도록 .gitignore로 차단되어 있습니다.)

# Airflow UID (Linux 호스트 전용, WSL/Windows 환경에서는 50000 유지 권장)
AIRFLOW_UID=50000

# Airflow 기본 스펙 설정
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.2
AIRFLOW__CORE__LOAD_EXAMPLES=false

# DAG 암호화 키 (보안상 난수 생성 값 입력 필수 - 예: cryptography.fernet.Fernet.generate_key().decode() 활용)
# 예시: FERNET_KEY=uq3G7b...
FERNET_KEY=YOUR_GENERATED_FERNET_KEY_HERE

# 컨테이너 기동 시 추가 로드가 필요한 패키지 리스트
_PIP_ADDITIONAL_REQUIREMENTS=
